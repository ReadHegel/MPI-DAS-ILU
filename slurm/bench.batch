#!/bin/bash
#SBATCH --nodes=4
#SBATCH --ntasks-per-node=24
#SBATCH --account "g105-2692"   
#SBATCH --time=00:05:00
#SBATCH --output=scaling_%j.out

MATRIX=matrices/cage10.mtx
echo "p,time" > results.csv

for p in 1 2 4 8 12 24 48 96
do
    srun -n $p ./example_test $MATRIX | awk -v p=$p '/^RESULT:/ {print p "," $2}' >> results.csv
done