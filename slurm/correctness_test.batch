#!/bin/bash -l
#SBATCH --job-name=ILU-correctness-large
#SBATCH --output=logs/correctness-%j.out
#SBATCH --error=logs/correctness-%j.err
#SBATCH --account=g105-2692
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=5
#SBATCH --time=00:02:00

set -euo pipefail

RUN_TIME=00:01:00

mkdir -p logs

# --- małe macierze (correctness szybki) — odkomentuj na później ---
MATRICES=(
    # matrices/cage3.mtx
    # matrices/cage4.mtx
    # matrices/cage5.mtx
    # matrices/identity.mtx
    # matrices/tridiag.mtx
    matrices/ex5.mtx
)
PROCS=(1 2 5)

# MATRICES=(
#     # matrices/Hook_1498.mtx
#     # matrices/cage14.mtx
#     matrices/cage15.mtx
# )

# # 1 node, 3 nodes, 6 nodes (po 24 ranki)
# PROCS=(1 3 5)

RESULTS=logs/correctness-${SLURM_JOB_ID}.csv
SUMMARY=logs/correctness-${SLURM_JOB_ID}-summary.txt

echo "matrix,procs,status,time" > "$RESULTS"
: > "$SUMMARY"

passed=0
failed=0

for MATRIX in "${MATRICES[@]}"; do
    for p in "${PROCS[@]}"; do
        echo "========================================"
        echo "=== matrix=$MATRIX  p=$p  limit=$RUN_TIME ==="
        echo "========================================"

        run_log=$(mktemp)
        set +e
        srun --label -n "$p" ./example_test "$MATRIX" > "$run_log" 2>&1
        exit_code=$?
        set -e

        cat "$run_log"

        time="-"
        if grep -q "^RESULT:" "$run_log"; then
            time=$(grep "^RESULT:" "$run_log" | awk '{print $2}')
        fi

        if [[ $exit_code -eq 0 ]] && grep -q "TEST PASSED" "$run_log"; then
            status="PASS"
            passed=$((passed + 1))
        else
            if [[ $exit_code -ne 0 ]]; then
                status="FAIL(exit=$exit_code)"
            else
                status="FAIL"
            fi
            failed=$((failed + 1))
        fi

        echo "$MATRIX,$p,$status,$time" >> "$RESULTS"
        echo "[$status] $MATRIX p=$p time=$time exit=$exit_code" >> "$SUMMARY"

        rm -f "$run_log"
        echo ""
    done
done

echo "========================================"
echo "Correctness summary"
echo "========================================"
cat "$SUMMARY"
echo "----------------------------------------"
echo "PASSED: $passed"
echo "FAILED: $failed"
echo "Results: $RESULTS"
echo "Summary: $SUMMARY"

if [[ $failed -gt 0 ]]; then
    exit 1
fi
